{
  "_version": "1.58.0",
  "sap.app": {
    "id": "ui5.fira.demos",
    "type": "application",
    "title": "Fira Demo Portal",
    "description": "Real-world UI5 application scenarios — ORKLABS.IO",
    "applicationVersion": { "version": "1.0.0" }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "ui5.fira.demos.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.f": {},
        "sap.tnt": {},
        "sap.uxap": {},
        "sap.ui.table": {},
        "sap.ui.unified": {}
      }
    },
    "resources": {
      "css": [{ "uri": "css/style.css" }]
    },
    "contentDensities": { "compact": true, "cozy": true },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "ui5.fira.demos.view",
        "controlId": "appNavContainer",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        { "name": "login",       "pattern": "login",       "target": "login"       },
        { "name": "launchpad",   "pattern": "",            "target": "launchpad"   },
        { "name": "po",          "pattern": "po",          "target": "po"          },
        { "name": "leave",       "pattern": "leave",       "target": "leave"       },
        { "name": "sales",       "pattern": "sales",       "target": "sales"       },
        { "name": "travel",      "pattern": "travel",      "target": "travel"      },
        { "name": "helpdesk",    "pattern": "helpdesk",    "target": "helpdesk"    },
        { "name": "onboarding",  "pattern": "onboarding",  "target": "onboarding"  },
        { "name": "assets",      "pattern": "assets",      "target": "assets"      },
        { "name": "quality",     "pattern": "quality",     "target": "quality"     },
        { "name": "budget",      "pattern": "budget",      "target": "budget"      },
        { "name": "warehouse",   "pattern": "warehouse",   "target": "warehouse"   },
        { "name": "playground",  "pattern": "playground",  "target": "playground"  },
        { "name": "kanban",      "pattern": "kanban",      "target": "kanban"      },
        { "name": "filtertable", "pattern": "filtertable", "target": "filtertable" },
        { "name": "empform",        "pattern": "empform",        "target": "empform"        },
        { "name": "stepinputtable", "pattern": "stepinputtable", "target": "stepinputtable" },
        { "name": "inputevents",    "pattern": "inputevents",    "target": "inputevents"    },
        { "name": "hrgrid",         "pattern": "hrgrid",         "target": "hrgrid"         },
        { "name": "calendar",       "pattern": "calendar",       "target": "calendar"       },
        { "name": "helpdesk-x",   "pattern": "helpdesk-x",   "target": "helpdesk-x"   },
        { "name": "leave-x",      "pattern": "leave-x",      "target": "leave-x"      },
        { "name": "travel-x",     "pattern": "travel-x",     "target": "travel-x"     },
        { "name": "po-x",         "pattern": "po-x",         "target": "po-x"         },
        { "name": "sales-x",      "pattern": "sales-x",      "target": "sales-x"      },
        { "name": "assets-x",     "pattern": "assets-x",     "target": "assets-x"     },
        { "name": "budget-x",     "pattern": "budget-x",     "target": "budget-x"     },
        { "name": "quality-x",    "pattern": "quality-x",    "target": "quality-x"    },
        { "name": "warehouse-x",  "pattern": "warehouse-x",  "target": "warehouse-x"  },
        { "name": "onboarding-x", "pattern": "onboarding-x", "target": "onboarding-x" },
        { "name": "kanban-x",     "pattern": "kanban-x",     "target": "kanban-x"     }
      ],
      "targets": {
        "login":      { "viewId": "login",      "viewName": "Login"                           },
        "launchpad":  { "viewId": "launchpad",  "viewName": "Launchpad"                       },
        "po":         { "viewId": "po",         "viewName": "apps.po.POApp"                  },
        "leave":      { "viewId": "leave",      "viewName": "apps.leave.LeaveApp"            },
        "sales":      { "viewId": "sales",      "viewName": "apps.sales.SalesApp"            },
        "travel":     { "viewId": "travel",     "viewName": "apps.travel.TravelApp"          },
        "helpdesk":   { "viewId": "helpdesk",   "viewName": "apps.helpdesk.HelpdeskApp"      },
        "onboarding": { "viewId": "onboarding", "viewName": "apps.onboarding.OnboardingApp"  },
        "assets":     { "viewId": "assets",     "viewName": "apps.assets.AssetApp"           },
        "quality":    { "viewId": "quality",    "viewName": "apps.quality.QualityApp"        },
        "budget":     { "viewId": "budget",     "viewName": "apps.budget.BudgetApp"          },
        "warehouse":  { "viewId": "warehouse",  "viewName": "apps.warehouse.WarehouseApp"    },
        "playground":  { "viewId": "playground",  "viewName": "apps.playground.PlaygroundApp"          },
        "kanban":      { "viewId": "kanban",      "viewName": "apps.kanban.KanbanApp"                  },
        "filtertable": { "viewId": "filtertable", "viewName": "apps.filtertable.FilterTableApp"        },
        "empform":        { "viewId": "empform",        "viewName": "apps.empform.EmpFormApp"                       },
        "stepinputtable": { "viewId": "stepinputtable", "viewName": "apps.stepinputtable.StepInputTableApp"    },
        "inputevents":    { "viewId": "inputevents",    "viewName": "apps.inputevents.InputEventsApp"          },
        "hrgrid":         { "viewId": "hrgrid",         "viewName": "apps.hrgrid.HRGridApp"                    },
        "calendar":       { "viewId": "calendar",       "viewName": "apps.calendar.CalendarApp"                },
        "helpdesk-x":   { "viewId": "helpdesk-x",   "viewName": "apps.helpdesk.HelpdeskAppX"    },
        "leave-x":      { "viewId": "leave-x",      "viewName": "apps.leave.LeaveAppX"          },
        "travel-x":     { "viewId": "travel-x",     "viewName": "apps.travel.TravelAppX"        },
        "po-x":         { "viewId": "po-x",         "viewName": "apps.po.POAppX"                },
        "sales-x":      { "viewId": "sales-x",      "viewName": "apps.sales.SalesAppX"          },
        "assets-x":     { "viewId": "assets-x",     "viewName": "apps.assets.AssetAppX"         },
        "budget-x":     { "viewId": "budget-x",     "viewName": "apps.budget.BudgetAppX"        },
        "quality-x":    { "viewId": "quality-x",    "viewName": "apps.quality.QualityAppX"      },
        "warehouse-x":  { "viewId": "warehouse-x",  "viewName": "apps.warehouse.WarehouseAppX"  },
        "onboarding-x": { "viewId": "onboarding-x", "viewName": "apps.onboarding.OnboardingAppX"},
        "kanban-x":     { "viewId": "kanban-x",     "viewName": "apps.kanban.KanbanAppX"        }
      }
    }
  }
}
